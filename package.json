{
  "name": "courtrank",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @courtrank/web dev",
    "build": "pnpm --filter @courtrank/web build",
    "start": "pnpm --filter @courtrank/web start",
    "mobile": "pnpm --filter @courtrank/mobile start",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "test": "pnpm -r test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "husky": "^9.1.7"
  }
}
