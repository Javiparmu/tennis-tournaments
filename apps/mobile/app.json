{
  "expo": {
    "name": "CourtRank",
    "slug": "courtrank",
    "scheme": "courtrank",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.courtrank.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.courtrank.mobile",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "expo-font",
      "expo-system-ui",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a0a",
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "88d8dbed-adf5-4515-a12d-1ec978f0dfe6"
      },
      "router": {}
    },
    "owner": "javiparmu"
  }
}
