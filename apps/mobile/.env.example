# Point at wherever the backend runs. On a physical device use your machine's LAN
# IP (or an Expo tunnel), not localhost.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
# Optional: defaults to 8000 when unset.
EXPO_PUBLIC_API_TIMEOUT_MS=8000
# Clerk publishable key — copy from the Clerk dashboard (API Keys).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
